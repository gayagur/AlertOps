# ============================================================================
# AlertOps — Alert Relay Agent Configuration
# ============================================================================
# Copy this file to .env and fill in your values.
# Lines starting with # are comments.
# ============================================================================

# ─── Database (REQUIRED) ─────────────────────────────────────────────────────
# PostgreSQL connection string using asyncpg driver.
# Format: postgresql+asyncpg://user:password@host:port/dbname
# For Render: use the "Internal Database URL" and replace postgresql:// with postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/alertops

# ─── Redis (REQUIRED) ────────────────────────────────────────────────────────
# Redis connection string for alert deduplication cache.
# Format: redis://[:password@]host:port/db_number
# For Render: use the Redis Internal URL from the Render dashboard.
REDIS_URL=redis://localhost:6379/0

# ─── Alert Source ─────────────────────────────────────────────────────────────
# Official public endpoint for alert data. Do not change unless the source changes.
# Default: https://www.oref.org.il/warningMessages/alert/History/AlertsHistory.json
ALERT_SOURCE_URL=https://www.oref.org.il/warningMessages/alert/History/AlertsHistory.json

# Polling interval in seconds. Lower = more real-time, higher = less load.
# Default: 3 (recommended for production)
POLL_INTERVAL_SECONDS=3

# ─── SendGrid — Email Notifications (OPTIONAL) ──────────────────────────────
# Without these, email notifications are skipped gracefully.
# Get your API key at: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=
# Sender email address. Must be verified in SendGrid.
# Default: alerts@alertops.app
SENDGRID_FROM_EMAIL=alerts@alertops.app

# ─── Twilio — SMS & WhatsApp Notifications (OPTIONAL) ───────────────────────
# Without these, SMS and WhatsApp notifications are skipped gracefully.
# Get credentials at: https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# The Twilio phone number to send SMS from (E.164 format, e.g., +15551234567)
TWILIO_FROM_PHONE=
# WhatsApp sender. Default is the Twilio sandbox number.
# For production, use your own approved WhatsApp Business number.
# Default: whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Security (REQUIRED for production) ──────────────────────────────────────
# Secret key for API authentication. Generate a strong random string.
# Example: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=change-me-to-a-random-string

# ─── Deduplication ────────────────────────────────────────────────────────────
# Time-to-live in seconds for dedup entries in Redis.
# Alerts older than this can be re-processed if they appear again.
# Default: 3600 (1 hour)
DEDUP_TTL=3600
