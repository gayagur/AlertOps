POLL_INTERVAL_SECONDS=3

# SendGrid (email)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=alerts@alertops.app

# Twilio (SMS + WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Security
API_SECRET_KEY=change-me-to-a-random-string
